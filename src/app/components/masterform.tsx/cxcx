
       
       
       
       <div className="mt-8 border rounded-xl p-6 bg-red-50">
          <h3 className="text-xl font-semibold text-red-800 mb-6 pb-3 border-b">
            <span className="bg-red-600 text-white px-3 py-1 rounded-md mr-2">4</span>
            Fleets Details 
          </h3>

            <div className="space-y-6">
           
                <h4 className="text-lg font-semibold text-gray-800 mb-4">Basic Vehicle Information</h4>
                <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 bg-red-50 gap-4">
                  <div>
                    <label className="block  text-md font-extrabold   text-gray-700 mb-1">
                      Registration Number <span className="text-red-500">*</span>
                    </label>
                    <div className="relative group">
                      <input
                        name="regNumber"
                        value={vehicleDraft.regNumber}
                        onChange={handleVehicleChange}
                        placeholder="e.g., MH01AB1234"
                        className={getVehicleInputClass(true)}
                        maxLength={getVehicleMaxLength("regNumber")}
                        required
                      />
                      <Truck className="absolute left-3 top-1/2 -translate-y-1/2 text-red-600 group-focus-within:animate-pulse" size={20} />
                    </div>
                  </div>
                  <div>
                    <label className="block  text-md font-extrabold   text-gray-700 mb-1">Registration Date</label>
                    <div className="relative group">
                      <input
                        name="regDate"
                        type="date"
                        value={vehicleDraft.regDate}
                        onChange={handleVehicleChange}
                        className={getVehicleInputClass(true)}
                      />
                      <Calendar className="absolute left-3 top-1/2 -translate-y-1/2 text-red-600 group-focus-within:animate-pulse" size={20} />
                    </div>
                  </div>
                  <div>
                    <label className="block  text-md font-extrabold   text-gray-700 mb-1">
                      Make <span className="text-red-500">*</span>
                    </label>
                    <div className="relative group">
                      <input
                        name="brand"
                        value={vehicleDraft.brand}
                        onChange={handleVehicleChange}
                        placeholder="e.g., Tata, Toyota"
                        className={getVehicleInputClass(true)}
                        maxLength={getVehicleMaxLength("brand")}
                        required
                      />
                      <Car className="absolute left-3 top-1/2 -translate-y-1/2 text-red-600 group-focus-within:animate-pulse" size={20} />
                    </div>
                  </div>
                  <div>
                    <label className="block  text-md font-extrabold   text-gray-700 mb-1">
                      Model <span className="text-red-500">*</span>
                    </label>
                    <div className="relative group">
                      <input
                        name="model"
                        value={vehicleDraft.model}
                        onChange={handleVehicleChange}
                        placeholder="e.g., Innova, XUV700"
                        className={getVehicleInputClass(true)}
                        maxLength={getVehicleMaxLength("model")}
                        required
                      />
                      <Car className="absolute left-3 top-1/2 -translate-y-1/2 text-red-600 group-focus-within:animate-pulse" size={20} />
                    </div>
                  </div>
                  <div>
                    <label className="block  text-md font-extrabold   text-gray-700 mb-1">
                      Vehicle Type <span className="text-red-500">*</span>
                    </label>
                    <div className="relative group">
                      <select
                        name="type"
                        value={vehicleDraft.type}
                        onChange={handleVehicleChange}
                        className={getVehicleInputClass(true)}
                        required
                      >
                        <option value="">Select type</option>
                        {vehicleTypes.map((item) => (
                          <option key={item} value={item}>
                            {item}
                          </option>
                        ))}
                      </select>
                      <Truck className="absolute left-3 top-1/2 -translate-y-1/2 text-red-600 group-focus-within:animate-pulse" size={20} />
                    </div>
                  </div>
                  <div>
                    <label className="block  text-md font-extrabold   text-gray-700 mb-1">
                      Fuel Type
                    </label>
                    <div className="relative group">
                      <select
                        name="fuel"
                        value={vehicleDraft.fuel}
                        onChange={handleVehicleChange}
                        className={getVehicleInputClass(true)}
                      >
                        <option value="">Select fuel</option>
                        {fuelTypes.map((item) => (
                          <option key={item} value={item}>
                            {item}
                          </option>
                        ))}
                      </select>
                      <Fuel className="absolute left-3 top-1/2 -translate-y-1/2 text-red-600 group-focus-within:animate-pulse" size={20} />
                    </div>
                  </div>

                  <div>
                    <label className="block  text-md font-extrabold   text-gray-700 mb-1">Category</label>
                    <div className="relative group">
                      <select
                        name="category"
                        value={vehicleDraft.category}
                        onChange={handleVehicleChange}
                        className={getVehicleInputClass(true)}
                      >
                        <option value="">Select category</option>
                        {['Economy', 'Premium', 'Luxury'].map((item) => (
                          <option key={item} value={item}>{item}</option>
                        ))}
                      </select>
                      <Users className="absolute left-3 top-1/2 -translate-y-1/2 text-red-600 group-focus-within:animate-pulse" size={20} />
                    </div>
                  </div>

                  <div>
                    <label className="block  text-md font-extrabold   text-gray-700 mb-1">
                      Manufacturing Year
                    </label>
                    <div className="relative group">
                      <input
                        name="year"
                        type="text"
                        value={vehicleDraft.year}
                        onChange={handleVehicleChange}
                        placeholder="e.g., 2023"
                        className={getVehicleInputClass(true)}
                        maxLength={getVehicleMaxLength("year")}
                        inputMode="numeric"
                      />
                      <Calendar className="absolute left-3 top-1/2 -translate-y-1/2 text-red-600 group-focus-within:animate-pulse" size={20} />
                    </div>
                  </div>
                  <div>
                    <label className="block  text-md font-extrabold   text-gray-700 mb-1">
                      Color
                    </label>
                    <div className="relative group">
                      <input
                        name="color"
                        value={vehicleDraft.color}
                        onChange={handleVehicleChange}
                        placeholder="e.g., White, Black"
                        className={getVehicleInputClass(true)}
                        maxLength={getVehicleMaxLength("color")}
                      />
                      <Palette className="absolute left-3 top-1/2 -translate-y-1/2 text-red-600 group-focus-within:animate-pulse" size={20} />
                    </div>
                  </div>
                  <div>
                    <label className="block  text-md font-extrabold   text-gray-700 mb-1">
                      Seating Capacity
                    </label>
                    <div className="relative group">
                      <input
                        name="seats"
                        type="text"
                        value={vehicleDraft.seats}
                        onChange={handleVehicleChange}
                        placeholder="Enter capacity"
                        className={getVehicleInputClass(true)}
                        maxLength={getVehicleMaxLength("seats")}
                        inputMode="numeric"
                      />
                      <Users className="absolute left-3 top-1/2 -translate-y-1/2 text-red-600 group-focus-within:animate-pulse" size={20} />
                    </div>
                  </div>
                  <div>
                    <label className="block  text-md font-extrabold   text-gray-700 mb-1">
                      Amenities
                    </label>
                    <div className="relative group">
                      <input
                        name="amenities"
                        value={vehicleDraft.amenities}
                        onChange={handleVehicleChange}
                        placeholder="e.g., AC, Music System, GPS"
                        className={getVehicleInputClass(true)}
                        maxLength={getVehicleMaxLength("amenities")}
                      />
                      <Star className="absolute left-3 top-1/2 -translate-y-1/2 text-red-600 group-focus-within:animate-pulse" size={20} />
                    </div>
                  </div>
                  <div>
                    <label className="block  text-md font-extrabold   text-gray-700 mb-1">
                      Price per km (Rs)
                    </label>
                    <div className="relative group">
                      <input
                        name="pricePerKm"
                        type="text"
                        value={vehicleDraft.pricePerKm}
                        onChange={handleVehicleChange}
                        placeholder="e.g., 15"
                        className={getVehicleInputClass(true)}
                        maxLength={getVehicleMaxLength("pricePerKm")}
                        inputMode="numeric"
                      />
                      <DollarSign className="absolute left-3 top-1/2 -translate-y-1/2 text-red-600 group-focus-within:animate-pulse" size={20} />
                    </div>
                  </div>
                  <div className="lg:col-span-3">
                    <label className="block  text-md font-extrabold   text-gray-700 mb-1">Notes</label>
                    <div className="relative group">
                      <textarea
                        name="message"
                        value={vehicleDraft.message}
                        onChange={handleVehicleChange}
                        placeholder="Enter any additional message"
                        className={getVehicleTextareaClass(true)}
                        maxLength={getVehicleMaxLength("message")}
                        rows={3}
                      />
                      <MessageSquare className="absolute left-3 top-3 text-red-600 group-focus-within:animate-pulse" size={20} />
                    </div>
                  </div>
                
              </div>
              
        <div className="mt-8">
          <h3 className="text-lg font-semibold text-gray-900 mb-4">Registered Vehicles</h3>
          <div className="border rounded-lg overflow-hidden">
            <table className="min-w-full divide-y divide-gray-200">
              <thead className="bg-gray-50">
                <tr>
                  <th className="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Vehicle No</th>
                  <th className="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
                  <th className="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Category</th>
                  <th className="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Seats</th>
                  <th className="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Fuel</th>
                  <th className="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Driver</th>
                </tr>
              </thead>
              <tbody className="bg-white divide-y divide-gray-200">
                {vehicles.length === 0 ? (
                  <tr>
                    <td className="px-4 py-5 text-center text-gray-500" colSpan={6}>
                      No vehicles added yet. Use "Add Vehicle" to register your fleet.
                    </td>
                  </tr>
                ) : (
                  vehicles.map((vehicle) => (
                    <tr key={vehicle._id}>
                      <td className="px-4 py-4 whitespace-nowrap  text-md font-extrabold   text-gray-900">
                        {vehicle.plate}
                      </td>
                      <td className="px-4 py-4 whitespace-nowrap text-sm text-gray-600">
                        {vehicle.type}
                      </td>
                      <td className="px-4 py-4 whitespace-nowrap text-sm text-gray-600">
                        {vehicle.category}
                      </td>
                      <td className="px-4 py-4 whitespace-nowrap text-sm text-gray-600">
                        {vehicle.seats ?? "—"}
                      </td>
                      <td className="px-4 py-4 whitespace-nowrap text-sm text-gray-600">
                        {vehicle.fuelType ?? "—"}
                      </td>
                      <td className="px-4 py-4 whitespace-nowrap text-sm text-gray-600">
                        {vehicle.assignedDriver?.licenseNumber || "Unassigned"}
                      </td>
                    </tr>
                  ))
                )}
              </tbody>
            </table>
          </div>
        </div>
        </div>
